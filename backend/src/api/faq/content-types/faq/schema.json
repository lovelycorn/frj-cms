{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "常见问题",
    "description": "Frequently asked questions"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true,
      "minLength": 3,
      "maxLength": 180
    },
    "slug": {
      "type": "uid",
      "targetField": "question",
      "required": true
    },
    "answer": {
      "type": "richtext",
      "required": true
    },
    "category": {
      "type": "string",
      "maxLength": 80
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  }
}
