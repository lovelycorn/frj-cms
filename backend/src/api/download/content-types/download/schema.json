{
  "kind": "collectionType",
  "collectionName": "downloads",
  "info": {
    "singularName": "download",
    "pluralName": "downloads",
    "displayName": "下载资料",
    "description": "Brochures, manuals and product documents"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 2,
      "maxLength": 120
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"],
      "required": true
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "downloads"
    }
  }
}
