{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "产品",
    "description": "Industrial product catalog"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 2,
      "maxLength": 120
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "rich_text": {
      "type": "richtext"
    },
    "specifications": {
      "type": "component",
      "repeatable": true,
      "component": "product.specification-item"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "pdf_attachments": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["files"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "industries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::industry.industry",
      "inversedBy": "products"
    },
    "downloads": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::download.download",
      "inversedBy": "products"
    },
    "certificates": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::certificate.certificate",
      "inversedBy": "products"
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 120
    },
    "seoDescription": {
      "type": "text",
      "maxLength": 320
    }
  }
}
