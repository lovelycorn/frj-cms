# FRJ CMS development environment template
# Copy to .env.development on macOS development machines.

NODE_ENV=development
SITE_CODE=us

NEXT_PUBLIC_API_URL=http://localhost:1337
STRAPI_URL=http://strapi:1337
STRAPI_PUBLIC_URL=http://localhost:1337
APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

NODE_IMAGE=node:20-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
NPM_REGISTRY=https://registry.npmmirror.com

POSTGRES_DB=frjcms
POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432

STRAPI_BIND_ADDR=127.0.0.1
STRAPI_PORT=1337
NEXT_BIND_ADDR=127.0.0.1
NEXT_PORT=3000

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=frjcms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_URL=postgresql://strapi:strapi@postgres:5432/frjcms

APP_KEYS=changeMeAppKey1,changeMeAppKey2,changeMeAppKey3,changeMeAppKey4
API_TOKEN_SALT=changeMeApiTokenSalt
ADMIN_JWT_SECRET=changeMeAdminJwtSecret
TRANSFER_TOKEN_SALT=changeMeTransferSalt
JWT_SECRET=changeMeJwtSecret
ENCRYPTION_KEY=changeMeEncryptionKey

STRAPI_ADMIN_EMAIL=admin@example.com
STRAPI_ADMIN_PASSWORD=Admin123456!

# Optional: when set, POST /api/analytics/events must include
# x-analytics-ingest-token header with the same value.
ANALYTICS_INGEST_TOKEN=
