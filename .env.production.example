# ------------------------------------------------------------
# FRJ CMS production environment template
# Copy to .env.production on production host, then replace ALL secrets.
# ------------------------------------------------------------

NODE_ENV=production
SITE_CODE=us

# Public URLs (for browser)
APP_URL=https://www.example.com
NEXT_PUBLIC_API_URL=https://cms.example.com
STRAPI_PUBLIC_URL=https://cms.example.com

# Internal service URL (for Next.js server-side requests in Docker network)
STRAPI_URL=http://strapi-prod:1337

# Docker image mirrors (optional)
NODE_IMAGE=node:20-bookworm-slim
POSTGRES_IMAGE=postgres:16-alpine
NPM_REGISTRY=https://registry.npmjs.org

# Host bindings. Production defaults are localhost-only; expose 80/443 through Nginx.
NEXT_BIND_ADDR=127.0.0.1
STRAPI_BIND_ADDR=127.0.0.1
POSTGRES_BIND_ADDR=127.0.0.1
NEXT_PORT=3000
STRAPI_PORT=1337
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_DB=frjcms
POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi

# Strapi database connection
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=frjcms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_URL=postgresql://strapi:strapi@postgres:5432/frjcms

# Strapi app secrets (replace with long random strings)
APP_KEYS=changeMeAppKey1,changeMeAppKey2,changeMeAppKey3,changeMeAppKey4
API_TOKEN_SALT=changeMeApiTokenSalt
ADMIN_JWT_SECRET=changeMeAdminJwtSecret
TRANSFER_TOKEN_SALT=changeMeTransferSalt
JWT_SECRET=changeMeJwtSecret
ENCRYPTION_KEY=changeMeEncryptionKey

# Initial admin account (used on first bootstrap only)
STRAPI_ADMIN_EMAIL=admin@example.com
STRAPI_ADMIN_PASSWORD=Admin123456!
